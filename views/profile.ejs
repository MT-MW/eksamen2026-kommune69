<%- include('./partials/head.ejs') %>
<%- include('./partials/nav.ejs') %>

<%- include('./partials/flashMessage.ejs') %>

<h1>Velkommen <%= bruker.fornavn %> <%= bruker.etternavn %></h1>

<div>
    <h2>Dine Hendelser</h2>  
    <form action="/ny-hendelse" method="get">
        <button type="submit">Registrer ny hendelse</button>
    </form>  
</div>

<% if( results.length > 0 ) { %>
    <% results.forEach(res => { %>
        <%- include('./partials/hendelsePreview.ejs', { res }) %>
    <% }); %>
<% } else { %>
    <p>Du har ingen tildelte hendelser</p>
<% } %>

<form action="/logg-ut" method="post">
    <button type="submit">Logg Ut</button>
</form>

<form action="/slett-bruker/<%= bruker._id %>" method="post">
    <button type="submit">Slett bruker</button>
</form>

<%- include('./partials/foot.ejs') %>